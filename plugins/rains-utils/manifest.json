{
  "id": "rain-utils",
  "name": "Rain's Utils",
  "version": "1.3.0",
  "manifestURI": "https://raw.githubusercontent.com/unkn0wncode/seanime-plugins/main/plugins/rains-utils/manifest.json",
  "language": "typescript",
  "type": "plugin",
  "description": "Remembers your player choices: subtitles, captions and video quality.",
  "author": "unkn0wncode",
  "icon": "https://raw.githubusercontent.com/unkn0wncode/seanime-plugins/main/plugins/rains-utils/icon.png",
  "website": "https://github.com/unkn0wncode/seanime-plugins",
  "lang": "multi",
  "payloadURI": "https://raw.githubusercontent.com/unkn0wncode/seanime-plugins/main/plugins/rains-utils/plugin.ts",
  "plugin": {
    "version": "1",
    "permissions": {
      "scopes": [
        "playback",
        "storage"
      ],
      "allow": {
        "unsafeFlags": [
          {
            "flag": "dom-script-manipulation",
            "reason": "Restore your saved video quality by operating the player's Quality menu (Seanime exposes no quality API to plugins)."
          }
        ]
      }
    }
  }
}
